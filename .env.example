# Database
DATABASE_URL=./data/openclaw.db

# Server
NODE_ENV=development
LOG_LEVEL=info

# Orchestrator
ORCHESTRATOR_TICK_MS=5000
HEARTBEAT_TIMEOUT_MS=30000

# HTTP Transport (optional)
HTTP_PORT=3100

# Proxy
PROXY_PORT=3101

# ── Commander LLM (Claude Max via Claude Code) ──
COMMANDER_API_BASE=https://api.anthropic.com
COMMANDER_API_KEY=your-anthropic-api-key
COMMANDER_MODEL=claude-sonnet-4-20250514

# ── Worker LLM (cheap API for small agents) ──
WORKER_API_BASE=https://api.x-or.cloud/dev/aiwm/deployments/YOUR_DEPLOYMENT/inference/v1
WORKER_API_KEY=your-worker-api-key
WORKER_MODEL=gpt-4o-mini

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_DEFAULT_TENANT_ID=
